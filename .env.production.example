# Environment Variables untuk Production (Vercel)
# SALIN FILE INI KE .env.production DAN ISI NILAI YANG SESUAI

# ─── DATABASE ──────────────────────────────────────
# Dapatkan dari Railway/PlanetScale/Supabase
# Format: mysql://username:password@host:port/database
DATABASE_URL="mysql://user:password@host:3306/database_name"

# ─── NEXTAUTH ──────────────────────────────────────
# Generate secret: https://generate-secret.vercel.app/32
# Atau jalankan: openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-random-string-panjang-dan-aman"

# URL aplikasi Anda setelah deploy (WAJIB HTTPS)
NEXTAUTH_URL="https://your-project.vercel.app"

# ─── CLOUDINARY (Upload Gambar) ────────────────────
# Daftar di: https://cloudinary.com
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── RESEND (Email) ────────────────────────────────
# Daftar di: https://resend.com
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="noreply@yourdomain.com"
